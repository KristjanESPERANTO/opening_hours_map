{
  "name": "opening-hours-map",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Interactive map showing opening_hours tags from OpenStreetMap",
  "scripts": {
    "build": "rollup -c",
    "dev": "vite --open '/?mock=true&lat=50.7374&lon=7.1106&zoom=13'",
    "fix": "npm run lint:fix && npm run format:fix",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "npm run test:unit && npm run test:html && npm run lint && npm run format:check",
    "test:unit": "node --test 'test/unit/**/*.test.js'",
    "test:html": "html-validate 'index.html'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "html-validate": "^11.5.3",
    "prettier": "^3.9.6",
    "rollup": "^4.62.0",
    "vite": "^8.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opening-hours/opening_hours_map.git"
  },
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "ol": "^10.9.0"
  }
}
